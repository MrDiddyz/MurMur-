{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["apps/api/src/**/*.ts", "apps/worker/src/**/*.ts", "services/**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
