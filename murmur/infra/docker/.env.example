NODE_ENV=production
HOST=0.0.0.0

# Database / Redis
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/ai_agent_platform?schema=public
REDIS_HOST=redis
REDIS_PORT=6379

# Service ports (internal container ports)
API_PORT=3001
SCHEDULER_PORT=3002
ORCHESTRATOR_PORT=3003
SANDBOX_PORT=3005
REPO_MANAGER_PORT=3007
REVIEW_GATE_PORT=3010
WEB_PORT=3000

# Internal service URLs
ORCHESTRATOR_URL=http://orchestrator:3003
REVIEW_GATE_URL=http://review-gate:3010
REPO_MANAGER_URL=http://repo-manager:3007
SANDBOX_URL=http://sandbox:3005
API_INTERNAL_URL=http://api:3001
WEB_INTERNAL_URL=http://web:3000

# Worker
WORKER_ID=worker-prod-1

# Local storage paths inside containers
REPO_STORAGE_ROOT=/tmp/ai-agent-platform/repos
SANDBOX_ROOT=/tmp/ai-agent-platform/sandboxes

# Nginx
NGINX_PORT=80

# Optional future secrets
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_KEY
