{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "module.health.v1",
  "title": "module.health.v1",
  "type": "object",
  "required": ["type", "timestamp", "module", "status"],
  "properties": {
    "type": {
      "const": "module.health.v1"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["healthy", "degraded", "down"]
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
