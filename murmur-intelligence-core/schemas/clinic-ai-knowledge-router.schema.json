{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://murmur.local/schema/clinic-ai-knowledge-router.schema.json",
  "title": "Clinic AI KnowledgeBase + Router Rules",
  "type": "object",
  "required": ["meta", "safety_policy", "routing", "knowledge_base"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["brand", "locale", "timezone", "version", "updated_at"],
      "additionalProperties": false,
      "properties": {
        "brand": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "default": "nb-NO" },
        "timezone": { "type": "string", "default": "Europe/Oslo" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "updated_at": { "type": "string", "format": "date-time" },
        "owner_contact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" }
          }
        }
      }
    },

    "safety_policy": {
      "type": "object",
      "required": ["disclaimer", "disallowed_content", "red_flags", "data_minimization"],
      "additionalProperties": false,
      "properties": {
        "disclaimer": {
          "type": "string",
          "minLength": 10,
          "description": "Shown when needed. Keep short and clear."
        },
        "disallowed_content": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Things the assistant must not do (diagnose, prescribe, dosage, etc.)."
        },
        "red_flags": {
          "type": "object",
          "required": ["message", "triggers"],
          "additionalProperties": false,
          "properties": {
            "message": { "type": "string", "minLength": 10 },
            "triggers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "pattern", "severity"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "pattern": {
                    "type": "string",
                    "minLength": 3,
                    "description": "Simple keyword/regex-ish pattern (implementation-defined)."
                  },
                  "severity": { "type": "string", "enum": ["low", "medium", "high"] }
                }
              }
            }
          }
        },
        "data_minimization": {
          "type": "object",
          "required": ["do_not_collect", "allowed_fields"],
          "additionalProperties": false,
          "properties": {
            "do_not_collect": {
              "type": "array",
              "items": { "type": "string" },
              "description": "E.g., diagnosis details, medication lists, journal data."
            },
            "allowed_fields": {
              "type": "array",
              "items": { "type": "string" },
              "description": "E.g., topic category, preferred contact method."
            }
          }
        }
      }
    },

    "routing": {
      "type": "object",
      "required": ["intents", "router_rules", "fallback"],
      "additionalProperties": false,
      "properties": {
        "intents": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["id", "description", "examples", "module"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 5 },
              "examples": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "module": {
                "type": "string",
                "enum": [
                  "faq",
                  "booking",
                  "pricing",
                  "service_overview",
                  "intake_triage",
                  "content_generation",
                  "handoff_human"
                ]
              },
              "priority": { "type": "integer", "minimum": 1, "maximum": 100, "default": 50 },
              "confidence_threshold": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "default": 0.55
              }
            }
          }
        },

        "router_rules": {
          "type": "array",
          "minItems": 3,
          "description": "Deterministic overrides before/after intent classification.",
          "items": {
            "type": "object",
            "required": ["id", "when", "then"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "when": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "contains_any": { "type": "array", "items": { "type": "string" } },
                  "contains_all": { "type": "array", "items": { "type": "string" } },
                  "matches_pattern": { "type": "string" },
                  "language": { "type": "string", "default": "nb" }
                }
              },
              "then": {
                "type": "object",
                "required": ["route_to"],
                "additionalProperties": false,
                "properties": {
                  "route_to": {
                    "type": "string",
                    "enum": [
                      "faq",
                      "booking",
                      "pricing",
                      "service_overview",
                      "intake_triage",
                      "content_generation",
                      "handoff_human",
                      "safety_red_flag"
                    ]
                  },
                  "set_flags": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "prepend_disclaimer": { "type": "boolean", "default": false }
                }
              }
            }
          }
        },

        "fallback": {
          "type": "object",
          "required": ["route_to", "message"],
          "additionalProperties": false,
          "properties": {
            "route_to": {
              "type": "string",
              "enum": ["faq", "service_overview", "handoff_human"]
            },
            "message": { "type": "string", "minLength": 5 }
          }
        }
      }
    },

    "knowledge_base": {
      "type": "object",
      "required": ["service", "offers", "links", "faq", "tone_snippets"],
      "additionalProperties": false,
      "properties": {
        "service": {
          "type": "object",
          "required": ["name", "description", "what_happens", "deliverable_after"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 20 },
            "what_happens": {
              "type": "array",
              "minItems": 2,
              "items": { "type": "string" }
            },
            "deliverable_after": { "type": "string", "minLength": 10 },
            "helps_with": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },

        "offers": {
          "type": "object",
          "required": ["intro_price", "regular_price", "vat_note"],
          "additionalProperties": false,
          "properties": {
            "intro_price": {
              "type": "object",
              "required": ["amount", "currency", "vat_included"],
              "additionalProperties": false,
              "properties": {
                "amount": { "type": "number", "minimum": 0 },
                "currency": { "type": "string", "default": "NOK" },
                "vat_included": { "type": "boolean" },
                "amount_with_vat": { "type": "number", "minimum": 0 }
              }
            },
            "regular_price": {
              "type": "object",
              "required": ["amount", "currency"],
              "additionalProperties": false,
              "properties": {
                "amount": { "type": "number", "minimum": 0 },
                "currency": { "type": "string", "default": "NOK" }
              }
            },
            "vat_note": { "type": "string" },
            "price_note": {
              "type": "string",
              "description": "E.g., intro price will increase later."
            }
          }
        },

        "links": {
          "type": "object",
          "required": ["booking_url", "website_url"],
          "additionalProperties": false,
          "properties": {
            "booking_url": { "type": "string", "format": "uri" },
            "website_url": { "type": "string", "format": "uri" },
            "contact_message_prompt": { "type": "string" }
          }
        },

        "faq": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": ["id", "q", "a", "tags"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "q": { "type": "string", "minLength": 5 },
              "a": { "type": "string", "minLength": 10 },
              "tags": {
                "type": "array",
                "items": { "type": "string" }
              },
              "cta": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "type": "string", "enum": ["book", "message", "read_more"] },
                  "label": { "type": "string" },
                  "url": { "type": "string", "format": "uri" }
                }
              }
            }
          }
        },

        "tone_snippets": {
          "type": "object",
          "required": ["greeting", "closing", "book_cta"],
          "additionalProperties": false,
          "properties": {
            "greeting": { "type": "string" },
            "closing": { "type": "string" },
            "book_cta": { "type": "string" }
          }
        }
      }
    }
  }
}
