{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "topology.changed.v1",
  "title": "topology.changed.v1",
  "type": "object",
  "required": ["type", "timestamp", "version", "modules"],
  "properties": {
    "type": {
      "const": "topology.changed.v1"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "dependsOn"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
