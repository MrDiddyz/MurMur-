generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id            String               @id @default(cuid())
  prompt        String
  status        String
  maxIterations Int
  result        String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  events        WorkflowEvent[]
  checkpoints   WorkflowCheckpoint[]
}

model WorkflowEvent {
  id         String   @id @default(cuid())
  workflowId String
  type       String
  message    String
  payload    Json?
  createdAt  DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model WorkflowCheckpoint {
  id         String   @id @default(cuid())
  workflowId String
  step       String
  data       Json
  createdAt  DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, step])
}

model Memory {
  id         String   @id @default(cuid())
  workflowId String
  content    String
  tags       String[]
  createdAt  DateTime @default(now())

  @@index([workflowId])
}
